rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menu items: anyone can read, only admin can write
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Orders: anyone can read and create, only authenticated can update
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null;
    }
    
    // Counters: open for client-side fallback (lock down with Cloud Functions on Blaze plan)
    match /counters/{counterId} {
      allow read, write: if true;
    }
    
    // Users: only authenticated user can read their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
